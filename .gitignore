# =============================================================================
# CopilotScan — .gitignore
# Python project + Microsoft 365 security tooling
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.python-version

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.hypothesis/
.pytest_cache/
nosetests.xml
test-results/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# Rope project
.ropeproject

# mkdocs / Sphinx
/site
docs/_build/
docs/_autosummary/

# PyInstaller
*.spec

# -----------------------------------------------------------------------------
# CopilotScan — sensitive runtime files
# -----------------------------------------------------------------------------

# MSAL token cache — NEVER commit (contains long-lived refresh tokens)
*.bin
token_cache*

# Local configuration with real tenant/client IDs
config.yaml
config.local.yaml
*.local.yaml
.env
.env.*
!.env.example

# Generated reports (may contain tenant agent metadata — treat as confidential)
report_*.html
scan_*.html
!examples/*.html
!tests/fixtures/*.html
!src/copilotscan/templates/*.html

# Raw API response dumps
raw_*.json
dump_*.json
!tests/fixtures/*.json
!examples/*.json

# Temporary scan artifacts
.copilotscan/
scan_output/

# -----------------------------------------------------------------------------
# Editors and IDEs
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains / PyCharm
.idea/
*.iml
*.iws
*.ipr

# -----------------------------------------------------------------------------
# Operating Systems
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
.cache/
*.log
*.tmp
*.bak
*.swp
*.swo
