# .env.example — copy to .env and fill in your values
# .env is excluded from git via .gitignore

COPILOTSCAN_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COPILOTSCAN_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Only required for --flow client_credentials
# COPILOTSCAN_CLIENT_SECRET=your-client-secret

# Optional: override default token cache location
# COPILOTSCAN_CACHE_PATH=~/.copilotscan/token_cache.bin
